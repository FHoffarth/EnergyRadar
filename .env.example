# Copy these values into your shell environment. EnergyRadar does not load
# .env files automatically.

# Safe provider-free preview
ENERGYRADAR_DEMO=1

# Live Fronius mode (replace with your own local device address)
FRONIUS_URL=http://192.0.2.10/solar_api/v1/GetPowerFlowRealtimeData.fcgi

# Optional Flask settings
ENERGYRADAR_HOST=127.0.0.1
ENERGYRADAR_PORT=5000
ENERGYRADAR_DEBUG=0
